<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tstapler.knock-sshd</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ ssh_bastion_install_dir }}/knock-sshd</string>
    <string>--config</string>
    <string>/etc/escutcheon/sshd.toml</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/var/log/knock-sshd.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/knock-sshd.log</string>
</dict>
</plist>
